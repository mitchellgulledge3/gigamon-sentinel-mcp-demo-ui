GigamonCcfMcpDemo_CL
| where TimeGenerated >= ago(24h)
| summarize Events=count(), FirstSeen=min(TimeGenerated), LastSeen=max(TimeGenerated), Protocols=make_set(protocol, 10), Apps=make_set(app_name, 10), AppFamilies=make_set(app_family, 10), TotalBytes=sum(tolong(total_bytes)), UniqueSources=dcount(src_ip), UniqueDestinations=dcount(dst_ip)
| project Events, FirstSeen, LastSeen, UniqueSources, UniqueDestinations, TotalBytes, Protocols, Apps, AppFamilies
